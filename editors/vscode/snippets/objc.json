    ],
    "description": "#pragma mark section divider"
  },
  "Try-catch": {
    "prefix": "trycatch",
    "body": [
      "@try {",
      "    ${1}",
      "} @catch (NSException *exception) {",
      "    ${2:NSLog(@\"Exception: %@\", exception);}",
      "} @finally {",
      "    ${0}",
      "}"
    ],
    "description": "@try/@catch/@finally block"
  }
}
