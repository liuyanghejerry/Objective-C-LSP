{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Objective-C",
  "scopeName": "source.objc",
  "fileTypes": ["m", "mm", "h"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#preprocessor" },
    { "include": "#compiler-directives" },
    { "include": "#message-send" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#storage-types" },
    { "include": "#objc-keywords" },
    { "include": "#block-literal" },
    { "include": "#method-declaration" },
    { "include": "#property-declaration" },
    { "include": "#selectors" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.documentation.objc",
          "begin": "/\\*[!*](?!/)",
          "end": "\\*/",
          "captures": {
            "0": { "name": "punctuation.definition.comment.objc" }
          }
        },
        {
          "name": "comment.block.objc",
          "begin": "/\\*",
          "end": "\\*/",
          "captures": {
            "0": { "name": "punctuation.definition.comment.objc" }
          }
        },
        {
          "name": "comment.line.double-slash.objc",
          "match": "//.*$"
        }
      ]
    },
    "preprocessor": {
      "patterns": [
        {
          "name": "meta.preprocessor.objc",
          "match": "^\\s*(#\\s*(?:if|ifdef|ifndef|elif|else|endif|define|undef|include|import|pragma|error|warning))\\b(.*)",
          "captures": {
            "1": { "name": "keyword.control.import.objc" },
            "2": { "name": "string.other.objc" }
          }
        }
      ]
    },
    "compiler-directives": {
      "patterns": [
        {
          "name": "keyword.control.objc",
          "match": "\\b(NS_ASSUME_NONNULL_BEGIN|NS_ASSUME_NONNULL_END|NS_UNAVAILABLE|NS_DESIGNATED_INITIALIZER|NS_REQUIRES_SUPER|NS_RETURNS_RETAINED|NS_RETURNS_NOT_RETAINED|NS_INLINE|NS_ENUM|NS_OPTIONS|NS_SWIFT_NAME|NS_REFINED_FOR_SWIFT)\\b"
        },
        {
          "name": "keyword.control.nullability.objc",
          "match": "\\b(nullable|nonnull|null_unspecified|null_resettable|_Nullable|_Nonnull|_Null_unspecified)\\b"
        }
      ]
    },
    "message-send": {
      "name": "meta.bracketed.objc",
      "begin": "\\[",
      "end": "\\]",
      "beginCaptures": {
        "0": { "name": "punctuation.section.bracket.begin.objc" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.section.bracket.end.objc" }
      },
      "patterns": [
        { "include": "#comments" },
        { "include": "#message-send" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#selectors" },
        { "include": "#keywords" },
        { "include": "#storage-types" },
        { "include": "#objc-keywords" },
        { "include": "#constants" },
        {
          "name": "entity.name.function.objc",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*:)"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.objc",
          "begin": "@\"",
          "end": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.objc" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.objc" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.objc",
              "match": "\\\\(x[0-9A-Fa-f]{2}|[0-2][0-7]{,2}|3[0-6][0-7]?|37[0-7]?|[4-7][0-7]?|.|$)"
            },
            {
              "name": "constant.other.placeholder.objc",
              "match": "%[\\-+ #0]*[0-9]*(\\.[0-9]+)?[hljztq]?[diouxXeEfgGcsSpaAn%@]"
            }
          ]
        },
        {
          "name": "string.quoted.double.objc",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.objc",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.objc",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.objc",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.objc",
          "match": "\\b0[xX][0-9a-fA-F]+[uUlL]*\\b"
        },
        {
          "name": "constant.numeric.objc",
          "match": "\\b(\\d+\\.?\\d*|\\.\\d+)([eE][+-]?\\d+)?[fFlL]?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.objc",
          "match": "\\b(if|else|for|while|do|switch|case|default|break|continue|return|goto|in)\\b"
        },
        {
          "name": "keyword.other.objc",
          "match": "\\b(sizeof|typeof|__typeof__|__typeof)\\b"
        }
      ]
    },
    "storage-types": {
      "patterns": [
        {
          "name": "storage.type.objc",
          "match": "\\b(void|char|short|int|long|float|double|signed|unsigned|bool|BOOL|id|Class|SEL|IMP|instancetype|NSInteger|NSUInteger|CGFloat|NSString|NSArray|NSDictionary|NSSet|NSNumber|NSObject|NSError|NSData|NSURL)\\b"
        },
        {
          "name": "storage.modifier.objc",
          "match": "\\b(static|extern|auto|register|volatile|const|restrict|__weak|__strong|__unsafe_unretained|__autoreleasing|weak|strong|copy|assign|retain|readonly|readwrite|nonatomic|atomic|class|getter|setter)\\b"
        }
      ]
    },
    "objc-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.objc",
          "match": "@(interface|implementation|protocol|end|class|selector|encode|synchronized|try|catch|finally|throw|autoreleasepool|import|required|optional|dynamic|synthesize|property|defs|compatibility_alias|available)"
        },
        {
          "name": "keyword.other.special-method.objc",
          "match": "\\b(super|self)\\b"
        },
        {
          "name": "constant.language.objc",
          "match": "\\b(YES|NO|Nil|nil|TRUE|FALSE|NULL)\\b"
        }
      ]
    },
    "block-literal": {
      "name": "meta.block-literal.objc",
      "begin": "(\\^)(\\s*\\([^)]*\\))?\\s*\\{",
      "end": "\\}",
      "beginCaptures": {
        "1": { "name": "keyword.operator.block.objc" },
        "2": { "name": "storage.type.block.parameter.objc" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.section.block.end.objc" }
      },
      "patterns": [
        { "include": "$self" }
      ]
    },
    "method-declaration": {
      "name": "meta.method-declaration.objc",
      "match": "^\\s*([-+])\\s*(?:\\(([^)]+)\\))?\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.operator.method-type.objc" },
        "2": { "name": "storage.type.return-type.objc" },
        "3": { "name": "entity.name.function.objc" }
      }
    },
    "property-declaration": {
      "name": "meta.property.objc",
      "match": "(@property)\\s*(\\([^)]*\\))?",
      "captures": {
        "1": { "name": "keyword.other.directive.objc" },
        "2": { "name": "storage.modifier.property-attributes.objc" }
      }
    },
    "selectors": {
      "patterns": [
        {
          "name": "entity.name.function.selector.objc",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*:(?:[^:]))"
        },
        {
          "name": "meta.selector-ref.objc",
          "match": "@selector\\(([^)]+)\\)",
          "captures": {
            "0": { "name": "keyword.other.directive.objc" },
            "1": { "name": "entity.name.function.selector.objc" }
          }
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "variable.other.constant.objc",
          "match": "\\bk[A-Z][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "variable.other.constant.uppercase.objc",
          "match": "\\b[A-Z][A-Z0-9_]{2,}\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.objc",
          "match": "(\\+\\+|--|->|&&|\\|\\||!|~|\\+|-|\\*|/|%|<<|>>|&|\\^|\\||==|!=|<=|>=|<|>|=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=|\\?|:)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.objc",
          "match": ";"
        },
        {
          "name": "punctuation.separator.objc",
          "match": ","
        }
      ]
    }
  }
}
