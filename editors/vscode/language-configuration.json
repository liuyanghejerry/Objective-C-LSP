{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] },
    { "open": "@\"", "close": "\"", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\?/\\s]+)",
  "indentationRules": {
    "increaseIndentPattern": "^((?!.*?/\\*).*\\*/)?(\\s*(\\bcase\\b.*:|\\bdefault\\b:|(\\bdo\\b|\\belse\\b|\\bfinally\\b|\\btry\\b|\\bfor\\b.*\\).*|\\bwhile\\b.*\\).*)\\s*)|.*\\{[^}\"'`]*|.*\\([^)\"'`]*)$",
    "decreaseIndentPattern": "^((?!.*?/\\*).*\\*/)?\\s*[\\}\\])].*$"
  }
}
