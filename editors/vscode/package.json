{
  "name": "objc-lsp",
  "displayName": "Objective-C Language Server",
  "description": "First-class Objective-C language support via objc-lsp (completion, hover, diagnostics, rename, and more)",
  "version": "0.3.0",
  "publisher": "liuyanghejerry",
  "license": "SEE LICENSE IN LICENSE",
  "icon": "icons/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/liuyanghejerry/Objective-C-LSP"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "platforms": [
    "darwin"
  ],
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters",
    "Snippets",
    "Other"
  ],
  "keywords": [
    "objective-c",
    "objc",
    "lsp",
    "language-server"
  ],
  "activationEvents": [
    "onLanguage:objective-c",
    "onLanguage:objective-cpp",
    "workspaceContains:**/*.m",
    "workspaceContains:**/*.mm",
    "workspaceContains:**/*.xcodeproj",
    "workspaceContains:**/*.h"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "objc-lsp-explorer",
          "title": "Objective-C",
          "icon": "$(symbol-class)"
        }
      ]
    },
    "views": {
      "objc-lsp-explorer": [
        {
          "id": "objcSymbolsOutline",
          "name": "Symbols Outline"
        },
        {
          "id": "objcClassBrowser",
          "name": "Class Browser"
        }
      ]
    },
    "languages": [
      {
        "id": "objective-c",
        "aliases": [
          "Objective-C",
          "objc"
        ],
        "extensions": [
          ".m",
          ".h"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "objective-cpp",
        "aliases": [
          "Objective-C++",
          "objcpp"
        ],
        "extensions": [
          ".mm"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "objective-c",
        "scopeName": "source.objc",
        "path": "./syntaxes/objc.tmLanguage.json"
      },
      {
        "language": "objective-cpp",
        "scopeName": "source.objcpp",
        "path": "./syntaxes/objc.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Objective-C LSP",
      "properties": {
        "objc-lsp.serverPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Absolute path to the `objc-lsp` binary. Leave empty to auto-discover from `$PATH` or the bundled binary."
        },
        "objc-lsp.logLevel": {
          "type": "string",
          "enum": [
            "error",
            "warn",
            "info",
            "debug"
          ],
          "default": "info",
          "description": "Log verbosity of the objc-lsp server process."
        },
        "objc-lsp.extraCompilerFlags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Extra flags passed to clang for every translation unit, e.g. `[\"-DDEBUG\", \"-I/usr/local/include\"]`."
        },
        "objc-lsp.enableNullabilityChecks": {
          "type": "boolean",
          "default": true,
          "description": "Report missing nullability annotations (NS_ASSUME_NONNULL regions)."
        },
        "objc-lsp.enableStaticAnalyzer": {
          "type": "boolean",
          "default": false,
          "description": "Run clang --analyze on save (slower; recommended only on explicit trigger)."
        },
        "objc-lsp.enableCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show Code Lens annotations (reference counts, protocol conformance) above methods."
        },
        "objc-lsp.enableDecorators": {
          "type": "boolean",
          "default": true,
          "description": "Show inline decorators for retain cycles, strong delegates, and magic numbers."
        },
        "objc-lsp.enableHoverExtensions": {
          "type": "boolean",
          "default": true,
          "description": "Show extended hover info: related methods, API availability, deprecation warnings, and quick-fix links."
        }
      }
    },
    "commands": [
      {
        "command": "objc-lsp.restart",
        "title": "ObjC: Restart Language Server"
      },
      {
        "command": "objc-lsp.showOutput",
        "title": "ObjC: Show Language Server Output"
      },
      {
        "command": "objc-lsp.reportIssue",
        "title": "ObjC: Report an Issue"
      },
      {
        "command": "objc-lsp.addProperty",
        "title": "ObjC: Generate @property from ivar"
      },
      {
        "command": "objc-lsp.wrapAutoreleasepool",
        "title": "ObjC: Wrap in @autoreleasepool"
      },
      {
        "command": "objc-lsp.wrapDispatchAsync",
        "title": "ObjC: Wrap in dispatch_async (main queue)"
      },
      {
        "command": "objc-lsp.addSynthesize",
        "title": "ObjC: Add @synthesize"
      },
      {
        "command": "objc-lsp.fixRetainCycle",
        "title": "ObjC: Fix Retain Cycle (add weakSelf)"
      },
      {
        "command": "objc-lsp.extractMethod",
        "title": "ObjC: Extract Method"
      },
      {
        "command": "objc-lsp.refreshClassBrowser",
        "title": "ObjC: Refresh Class Browser"
      },
      {
        "command": "objc-lsp.showCallGraph",
        "title": "ObjC: Show Call Graph"
      }
    ],
    "snippets": [
      {
        "language": "objective-c",
        "path": "./snippets/objc.json"
      },
      {
        "language": "objective-cpp",
        "path": "./snippets/objc.json"
      }
    ]
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "vsce package --target darwin-arm64",
    "package:intel": "vsce package --target darwin-x64",
    "lint": "eslint src --ext ts",
    "build:bin": "mkdir -p bin && cp ../../target/release/objc-lsp bin/objc-lsp-darwin-arm64",
    "build:bin:intel": "mkdir -p bin && cp ../../target/release/objc-lsp bin/objc-lsp-darwin-x64",
    "build:all": "npm run build:bin && npm run build:bin:intel",
    "build": "npm run build:all && npm run compile && npm run package",
    "install-ext": "code --install-extension objc-lsp-$(node -p \"require('./package.json').version\").vsix --force"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
